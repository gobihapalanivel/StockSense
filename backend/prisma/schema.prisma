generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Role {
  ADMIN
  INVENTORY_MANAGER
  CASHIER
}

enum BrandState {
  ACTIVE
  INACTIVE
  DISCONNECT
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum AdjustmentReason {
  DAMAGED
  LOST
  EXPIRED
  RETURNED
  COUNTING_ERROR
  SYSTEM_CORRECTION
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

// ─────────────────────────────────────
// MODELS
// ─────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CASHIER)
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  bills            Bill[]
  grns             GoodsReceivingNote[]
  stockAdjustments StockAdjustment[]
  refunds          Refund[]

  @@map("users")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  companyName String   @map("company_name")
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  grns                 GoodsReceivingNote[]
  masterProductClasses MasterProductClass[]

  @@map("suppliers")
}

model Category {
  id               String   @id @default(uuid()) @map("category_id")
  name             String   @unique
  description      String?
  categoryImageUrl String?  @map("category_image_url")
  isActive         Boolean  @default(true) @map("is_active")

  // Relations
  subCategories        SubCategory[]
  masterProductClasses MasterProductClass[]

  @@map("categories")
}

model SubCategory {
  id          String   @id @default(uuid()) @map("subc_id")
  name        String   @unique
  description String?
  categoryId  String   @map("category_id")
  isActive    Boolean  @default(true) @map("is_active")

  // Relations
  category             Category             @relation(fields: [categoryId], references: [id])
  masterProductClasses MasterProductClass[]

  @@map("sub_categories")
}

model Brand {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  state       BrandState @default(ACTIVE)

  // Relations
  masterProductClasses MasterProductClass[]

  @@map("brands")
}

model MasterProductClass {
  id            String       @id @default(uuid())
  name          String
  categoryId    String       @map("category_id")
  subCategoryId String?      @map("subcategory_id")
  brandId       String       @map("brand_id")
  supplierId    String       @map("supplier_id")
  hasVariant    Boolean      @default(false) @map("has_varient")
  createdAt     DateTime     @default(now()) @map("created_at")

  // Relations
  category    Category     @relation(fields: [categoryId], references: [id])
  subCategory SubCategory? @relation(fields: [subCategoryId], references: [id])
  brand       Brand        @relation(fields: [brandId], references: [id])
  supplier    Supplier     @relation(fields: [supplierId], references: [id])
  products    Product[]

  @@map("master_product_class")
}

model Product {
  sku                  String        @id @map("sku")
  masterId             String        @map("master_id")
  barcode              String        @unique
  name                 String
  unitType             String        @map("unit_type")
  costPrice            Float         @map("cost_price")
  sellingPrice         Float         @map("selling_price")
  discount             Float?        @default(0)
  currentStock         Int           @default(0) @map("current_stock")
  reorderLevel         Int           @default(25) @map("reorder_level")
  targetCapacity       Int           @map("target_capacity")
  mfgDate              DateTime?     @map("mfg_date") @db.Date
  expiryDate           DateTime?     @map("expiry_date") @db.Date
  status               ProductStatus @default(ACTIVE)
  imageUrl             String?       @map("image_url")
  batchNumber          String?       @map("batch_number")
  seasonal             String?       
  variantAttributeType String?       @map("variant_attribute_type")
  lowOrderLevel        Boolean?      @map("low_order_level")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  // Relations
  masterClass      MasterProductClass @relation(fields: [masterId], references: [id])
  grnItems         GrnItem[]
  stockAdjustments StockAdjustment[]
  billItems        BillItem[]
  discountProducts DiscountProduct[]
  comboItems       DiscountComboItem[]
  refundItems      RefundItem[]

  @@map("products")
}

model GoodsReceivingNote {
  id         String   @id @default(uuid())
  grnId      String   @unique @map("grn_id")
  supplierId String   @map("supplier_id")
  operatorId String   @map("operator_id")
  grnDate    DateTime @default(now()) @map("grn_date")
  notes      String?

  // Relations
  supplier Supplier  @relation(fields: [supplierId], references: [id])
  operator User      @relation(fields: [operatorId], references: [id])
  items    GrnItem[]

  @@map("goods_receiving_notes")
}

model GrnItem {
  id            String    @id @default(uuid())
  grnId         String    @map("grn_id")
  sku           String    @map("sku")
  addedQuantity Int       @map("added_quantity")
  finalQuantity Int       @map("final_quantity")
  unitCost      Float     @map("unit_cost")
  mfd           DateTime? @db.Date
  epd           DateTime? @db.Date

  // Relations
  grn     GoodsReceivingNote @relation(fields: [grnId], references: [id])
  product Product            @relation(fields: [sku], references: [sku])

  @@map("grn_items")
}

model StockAdjustment {
  id            String           @id @default(uuid())
  sku           String           @map("sku")
  qtyChanged    Int              @map("qty_changed")
  reason        AdjustmentReason
  adjustedById  String           @map("adjusted_by")
  finalQuantity Int              @map("final_quantity")
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations
  product    Product @relation(fields: [sku], references: [sku])
  adjustedBy User    @relation(fields: [adjustedById], references: [id])

  @@map("stock_adjustments")
}

model Bill {
  id             String        @id @default(uuid())
  billNumber     String        @unique @map("bill_number")
  cashierId      String        @map("cashier_id")
  subtotal       Float
  totalDiscount  Float?        @default(0) @map("total_discount")
  totalBill      Float         @map("total_bill")
  paymentMethod  PaymentMethod @default(CASH) @map("payment_method")
  draft          Boolean       @default(false)
  totalQty       Int           @map("total_qty")
  createdAt      DateTime      @default(now()) @map("created_at")

  // Relations
  cashier   User       @relation(fields: [cashierId], references: [id])
  billItems BillItem[]
  refunds   Refund[]

  @@map("sales_bills")
}

model BillItem {
  id            String  @id @default(uuid())
  billId        String  @map("bill_id")
  sku           String  @map("sku")
  qty           Int
  unitPrice     Float   @map("unit_price")
  total         Float
  discountId    String? @map("discount_id")
  discountValue Float?  @map("discount_value")

  // Relations
  bill     Bill      @relation(fields: [billId], references: [id])
  product  Product   @relation(fields: [sku], references: [sku])
  discount Discount? @relation(fields: [discountId], references: [id])

  @@map("sales_bill_items")
}

enum DiscountType {
  SEASONAL
  DAILY
  COMBO
  BILL
}

enum ApprovalStatus {
  DRAFT
  APPROVED
}

model Discount {
  id             String         @id @default(uuid())
  name           String
  type           DiscountType
  discountValue  Float          @default(0) @map("discount_value")
  comboPrice     Float?         @map("combo_price")
  minBillAmount  Float?         @map("min_bill_amount")
  label          String?
  imageUrl       String?        @map("image_url")
  startDate      DateTime?      @map("start_date") @db.Date
  endDate        DateTime?      @map("end_date") @db.Date
  dailyStartTime String?        @map("daily_start_time")
  dailyEndTime   String?        @map("daily_end_time")
  applicableDate DateTime?      @map("applicable_date") @db.Date
  isActive       Boolean        @default(true) @map("is_active")
  approvalStatus ApprovalStatus @default(DRAFT) @map("approval_status")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  discountProducts DiscountProduct[]
  comboItems       DiscountComboItem[]
  billItems        BillItem[]

  @@map("discounts")
}

model DiscountProduct {
  id         String   @id @default(uuid())
  discountId String   @map("discount_id")
  sku        String   @map("sku")

  // Relations
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@unique([discountId, sku])
  @@map("seasonal_or_daily_products")
}

model DiscountComboItem {
  id         String   @id @default(uuid())
  discountId String   @map("discount_id")
  sku        String   @map("sku")
  minQty     Int      @default(1) @map("min_qty")

  // Relations
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [sku], references: [sku], onDelete: Cascade)

  @@unique([discountId, sku])
  @@map("discount_combo_items")
}

model Refund {
  id              String       @id @default(uuid())
  refundNumber    String       @unique @map("refund_number")
  originalBillId  String       @map("original_bill_id")
  cashierId       String       @map("cashier_id")
  refundAmount    Float        @map("refund_amount")
  createdAt       DateTime     @default(now()) @map("created_at")

  // Relations
  originalBill    Bill         @relation(fields: [originalBillId], references: [id])
  cashier         User         @relation(fields: [cashierId], references: [id])
  refundItems     RefundItem[]

  @@map("sales_refunds")
}

model RefundItem {
  id            String   @id @default(uuid())
  refundId      String   @map("refund_id")
  sku           String   @map("sku")
  qty           Int
  refundValue   Float    @map("refund_value")

  // Relations
  refund        Refund   @relation(fields: [refundId], references: [id])
  product       Product  @relation(fields: [sku], references: [sku])

  @@map("sales_refund_items")
}

model GeneratedReport {
  id        String   @id @default(uuid())
  name      String
  category  String
  format    String
  status    String   @default("Ready")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("generated_reports")
}
