generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Role {
  ADMIN
  INVENTORY_MANAGER
  CASHIER
}

enum BrandState {
  ACTIVE
  INACTIVE
  DISCONNECT
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum AdjustmentReason {
  DAMAGED
  LOST
  EXPIRED
  RETURNED
  COUNTING_ERROR
  SYSTEM_CORRECTION
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

// ─────────────────────────────────────
// MODELS
// ─────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(CASHIER)
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  bills            Bill[]
  grns             GoodsReceivingNote[]
  stockAdjustments StockAdjustment[]

  @@map("users")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  companyName String   @map("company_name")
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  grns                 GoodsReceivingNote[]
  masterProductClasses MasterProductClass[]

  @@map("suppliers")
}

model Category {
  id               String   @id @default(uuid()) @map("category_id")
  name             String   @unique
  description      String?
  categoryImageUrl String?  @map("category_image_url")

  // Relations
  subCategories        SubCategory[]
  masterProductClasses MasterProductClass[]

  @@map("categories")
}

model SubCategory {
  id          String   @id @default(uuid()) @map("subc_id")
  name        String   @unique
  description String?
  categoryId  String   @map("category_id")

  // Relations
  category    Category @relation(fields: [categoryId], references: [id])

  @@map("sub_categories")
}

model Brand {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  state       BrandState @default(ACTIVE)

  // Relations
  masterProductClasses MasterProductClass[]

  @@map("brands")
}

model MasterProductClass {
  id         String   @id @default(uuid())
  name       String
  categoryId String   @map("category_id")
  brandId    String   @map("brand_id")
  supplierId String   @map("supplier_id")
  hasVariant Boolean  @default(false) @map("has_varient")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  category   Category  @relation(fields: [categoryId], references: [id])
  brand      Brand     @relation(fields: [brandId], references: [id])
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  products   Product[]

  @@map("master_product_class")
}

model Product {
  sku                  String        @id @map("sku")
  masterId             String        @map("master_id")
  barcode              String        @unique
  name                 String
  unitType             String        @map("unit_type")
  costPrice            Float         @map("cost_price")
  sellingPrice         Float         @map("selling_price")
  discount             Float?        @default(0)
  currentStock         Int           @default(0) @map("current_stock")
  reorderLevel         Int           @default(25) @map("reorder_level")
  targetCapacity       Int           @map("target_capacity")
  mfgDate              DateTime?     @map("mfg_date") @db.Date
  expiryDate           DateTime?     @map("expiry_date") @db.Date
  status               ProductStatus @default(ACTIVE)
  imageUrl             String?       @map("image_url")
  batchNumber          String?       @map("batch_number")
  seasonal             String?       
  variantAttributeType String?       @map("variant_attribute_type")
  lowOrderLevel        Boolean?      @map("low_order_level")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  // Relations
  masterClass      MasterProductClass @relation(fields: [masterId], references: [id])
  grnItems         GrnItem[]
  stockAdjustments StockAdjustment[]
  billItems        BillItem[]

  @@map("products")
}

model GoodsReceivingNote {
  id         String   @id @default(uuid())
  grnId      String   @unique @map("grn_id")
  supplierId String   @map("supplier_id")
  operatorId String   @map("operator_id")
  grnDate    DateTime @default(now()) @map("grn_date")
  notes      String?

  // Relations
  supplier Supplier  @relation(fields: [supplierId], references: [id])
  operator User      @relation(fields: [operatorId], references: [id])
  items    GrnItem[]

  @@map("goods_receiving_notes")
}

model GrnItem {
  id            String    @id @default(uuid())
  grnId         String    @map("grn_id")
  sku           String    @map("sku")
  addedQuantity Int       @map("added_quantity")
  finalQuantity Int       @map("final_quantity")
  unitCost      Float     @map("unit_cost")
  mfd           DateTime? @db.Date
  epd           DateTime? @db.Date

  // Relations
  grn     GoodsReceivingNote @relation(fields: [grnId], references: [id])
  product Product            @relation(fields: [sku], references: [sku])

  @@map("grn_items")
}

model StockAdjustment {
  id            String           @id @default(uuid())
  sku           String           @map("sku")
  qtyChanged    Int              @map("qty_changed")
  reason        AdjustmentReason
  adjustedById  String           @map("adjusted_by")
  finalQuantity Int              @map("final_quantity")
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations
  product    Product @relation(fields: [sku], references: [sku])
  adjustedBy User    @relation(fields: [adjustedById], references: [id])

  @@map("stock_adjustments")
}

model Bill {
  id             String        @id @default(uuid())
  billNumber     String        @unique @map("bill_number")
  cashierId      String        @map("cashier_id")
  subtotal       Float
  totalDiscount  Float?        @default(0) @map("total_discount")
  totalBill      Float         @map("total_bill")
  paymentMethod  PaymentMethod @default(CASH) @map("payment_method")
  draft          Boolean       @default(false)
  totalQty       Int           @map("total_qty")
  createdAt      DateTime      @default(now()) @map("created_at")

  // Relations
  cashier   User       @relation(fields: [cashierId], references: [id])
  billItems BillItem[]

  @@map("sales_bills")
}

model BillItem {
  id            String  @id @default(uuid())
  billId        String  @map("bill_id")
  sku           String  @map("sku")
  qty           Int
  unitPrice     Float   @map("unit_price")
  total         Float
  discountId    String? @map("discount_id")
  discountValue Float?  @map("discount_value")

  // Relations
  bill    Bill    @relation(fields: [billId], references: [id])
  product Product @relation(fields: [sku], references: [sku])

  @@map("sales_bill_items")
}
