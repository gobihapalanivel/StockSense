generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Role {
  ADMIN
  CASHIER
  INVENTORY_MANAGER
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum PaymentStatus {
  PAID
  PENDING
  REFUNDED
}

enum AdjustmentType {
  INCREASE
  DECREASE
}

// ─────────────────────────────────────
// TABLE 1: users
// ─────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(CASHIER)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Self-referencing: Admin who created this user
  createdById String?
  createdBy   User?    @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers User[]  @relation("CreatedUsers")

  // Relations
  bills              Bill[]
  purchaseOrders     PurchaseOrder[]
  stockAdjustments   StockAdjustment[]

  @@map("users")
}

// ─────────────────────────────────────
// TABLE 2: categories
// ─────────────────────────────────────
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  // Relations
  products    Product[]

  @@map("categories")
}

// ─────────────────────────────────────
// TABLE 3: products
// ─────────────────────────────────────
model Product {
  id                String    @id @default(uuid())
  name              String
  barcode           String    @unique
  categoryId        String
  price             Float
  costPrice         Float
  stock             Int       @default(0)
  lowStockThreshold Int       @default(10)
  unit              String    @default("piece")
  expiryDate        DateTime?
  imageUrl          String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  category          Category        @relation(fields: [categoryId], references: [id])
  purchaseItems     PurchaseItem[]
  billItems         BillItem[]
  stockAdjustments  StockAdjustment[]

  @@map("products")
}

// ─────────────────────────────────────
// TABLE 4: suppliers
// ─────────────────────────────────────
model Supplier {
  id            String    @id @default(uuid())
  name          String
  contactPerson String?
  phone         String
  email         String?
  address       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  // Relations
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// ─────────────────────────────────────
// TABLE 5: purchase_orders
// ─────────────────────────────────────
model PurchaseOrder {
  id           String         @id @default(uuid())
  supplierId   String
  managerId    String
  status       PurchaseStatus @default(PENDING)
  totalAmount  Float
  invoiceNo    String?
  orderedAt    DateTime       @default(now())
  receivedAt   DateTime?
  notes        String?

  // Relations
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  manager       User           @relation(fields: [managerId], references: [id])
  purchaseItems PurchaseItem[]

  @@map("purchase_orders")
}

// ─────────────────────────────────────
// TABLE 6: purchase_items
// ─────────────────────────────────────
model PurchaseItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  costPrice       Float
  totalCost       Float

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ─────────────────────────────────────
// TABLE 7: bills
// ─────────────────────────────────────
model Bill {
  id              String        @id @default(uuid())
  cashierId       String
  subtotal        Float
  discountAmount  Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PAID)
  customerName    String?
  customerPhone   String?
  createdAt       DateTime      @default(now())

  // Relations
  cashier         User          @relation(fields: [cashierId], references: [id])
  billItems       BillItem[]

  @@map("bills")
}

// ─────────────────────────────────────
// TABLE 8: bill_items
// ─────────────────────────────────────
model BillItem {
  id          String   @id @default(uuid())
  billId      String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  // Relations
  bill        Bill     @relation(fields: [billId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@map("bill_items")
}

// ─────────────────────────────────────
// TABLE 9: stock_adjustments
// ─────────────────────────────────────
model StockAdjustment {
  id          String         @id @default(uuid())
  productId   String
  userId      String
  type        AdjustmentType
  quantity    Int
  reason      String
  beforeStock Int
  afterStock  Int
  createdAt   DateTime       @default(now())

  // Relations
  product     Product        @relation(fields: [productId], references: [id])
  user        User           @relation(fields: [userId], references: [id])

  @@map("stock_adjustments")
}
